{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Endpoint",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Endpoint name"
    },
    "type": {
      "type": "string",
      "description": "Endpoint type"
    },
    "accountId": {
      "type": "string"
    },
    "provider": {
      "type": "object"
    },
    "compute": {
      "type": "object"
    },
    "model": {
      "type": "object"
    },
    "status": {
      "type": "object"
    },
    "url": {
      "type": "string",
      "description": "Inference URL for the endpoint"
    }
  }
}